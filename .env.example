# 环境变量配置模板
# 复制此文件为 .env.local（不会被 git 提交），或直接在 Vercel Dashboard 配置
#
# Vercel Dashboard → 项目 Settings → Environment Variables
# 添加以下三个变量（每个都要在 Production / Preview / Development 三个环境都勾选）

LLM_API_URL=https://api.zhtunnel.com/v1/chat/completions
LLM_API_KEY=sk-your-zhtunnel-key-here
LLM_MODEL=gpt-4o-mini

# 模型说明：
# gpt-4o-mini   — 速度快、成本低，适合日常对话（推荐默认）
# gpt-4o        — 能力最强，速度较慢，成本较高
# claude-3.5-sonnet — 适合复杂分析
# gemini-1.5-flash — 适合快速总结
# 豆包-pro       — 国产模型，性价比高